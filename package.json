{
  "name": "a11y-static-scanner",
  "version": "1.0.0",
  "description": "MCP server for WCAG 2.2 accessibility analysis of React repositories",
  "type": "module",
  "bin": {
    "a11y-static-scanner": "./dist/index.js",
    "a11y-scan": "./dist/a11y-scan.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:cli": "tsx src/a11y-scan.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "adm-zip": "^0.5.12",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "exceljs": "^4.4.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "pdfkit": "^0.15.0",
    "simple-git": "^3.22.0",
    "tmp-promise": "^3.0.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/babel__traverse": "^7.20.6",
    "@types/eslint": "^8.56.0",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
